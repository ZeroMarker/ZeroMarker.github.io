---
import AppCard from '../components/AppCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { apps } from '../data/apps';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="我的工具箱 | Zeromark Apps"
  description="Zeromark 的常用小工具集合，包含单词记忆、数字游戏和 SIM 卡保号信息。"
>
  <ThemeToggle />

  <main class="page-shell">
    <header class="hero">
      <p class="eyebrow">Zeromark Apps</p>
      <h1>我的工具箱</h1>
      <p class="subtitle">常用小工具集合，随时打开就能用。</p>
    </header>

    <section class="apps-grid" aria-label="工具列表">
      {apps.map((app) => <AppCard app={app} />)}
    </section>
  </main>

  <footer class="site-footer">© {new Date().getFullYear()} Zeromark</footer>
</BaseLayout>
